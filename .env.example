# Polymarket Tmax Forecaster - environment variables template.
#
# COPY this file to `.env` and fill the values.
# `.env` is git-ignored. Never commit a real `.env`.
#
# Required only when phases that need them are enabled.

# Open-Meteo Customer API key (only required if moving away from the free tier
# for live commercial use; backfill in v1 uses the free tier without a key).
# OPEN_METEO_API_KEY=

# Polymarket / market access (Phase 8). Leave empty during Phases 1-3.
# POLYMARKET_API_KEY=
# POLYMARKET_EVENT_URL=

# Local paths overrides (defaults read from nzwn/config/*.yaml)
# TMAX_LOG_ROOT=artifacts/logs
# TMAX_DATA_ROOT=artifacts/raw
